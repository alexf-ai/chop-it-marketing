# Chop it marketing site — environment variables
#
# Copy to .env.local (gitignored). Never commit .env.local.
# Only public/anon keys belong here — this is a read-only marketing site.

# Supabase — use the ANON key only. Never the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostHog — chopit-marketing project (NOT chopit-product)
# Get from https://eu.posthog.com → chopit-marketing → Settings → Project API Key
# The /ingest reverse-proxy in next.config.mjs routes ingestion through
# eu.i.posthog.com, so there is no separate host env var.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_placeholder

# Revalidation webhook secret (Supabase webhook → /api/revalidate).
# 64-char hex string: `openssl rand -hex 32`.
REVALIDATION_SECRET=replace-with-openssl-rand-hex-32

# App-store CTA targets (used by RecipeCTA + DownloadCTA). '#' fallback if unset.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=
# Set to 'true' to expose the Google Play badge. Hidden otherwise.
NEXT_PUBLIC_ANDROID_LIVE=false

# Cloudflare Turnstile (waitlist anti-bot). Site key is public, safe to
# expose to the browser. Pair with TURNSTILE_SECRET as a Supabase Edge
# Function secret on the waitlist-submit function.
# When unset, the waitlist form skips Turnstile entirely (env-gated).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
